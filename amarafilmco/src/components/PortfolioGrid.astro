---
import { siteConfig } from "../site.config";

const items = siteConfig.portfolio;
const filters = siteConfig.portfolioFilters;
---

<div class="filter-bar" role="tablist" aria-label="Filter portfolio">
  {
    filters.map((f) => (
      <button type="button" role="tab" data-filter={f.id} aria-pressed={f.id === "all" ? "true" : "false"}>
        {f.label}
      </button>
    ))
  }
</div>

<div class="portfolio-grid" id="portfolioGrid">
  {
    items.map((item, i) => (
      <figure data-category={item.category}>
        <button type="button" data-lightbox-index={i} aria-label={`Open image: ${item.alt}`}>
          <img src={item.src} alt={item.alt} width="800" height="1000" loading={i < 3 ? "eager" : "lazy"} />
        </button>
      </figure>
    ))
  }
</div>

<div id="lightbox" class="lightbox-backdrop" hidden>
  <div class="lightbox-inner">
    <button type="button" class="lightbox-close" aria-label="Close">&times;</button>
    <button type="button" class="lightbox-prev" aria-label="Previous">&#8249;</button>
    <img id="lightboxImg" src="" alt="" />
    <button type="button" class="lightbox-next" aria-label="Next">&#8250;</button>
  </div>
</div>

<script define:vars={{ portfolioItems: items }}>
  (function () {
    var items = portfolioItems;
    var grid = document.getElementById("portfolioGrid");
    var lb = document.getElementById("lightbox");
    var imgEl = document.getElementById("lightboxImg");
    var closeBtn = lb && lb.querySelector(".lightbox-close");
    var prevBtn = lb && lb.querySelector(".lightbox-prev");
    var nextBtn = lb && lb.querySelector(".lightbox-next");
    var current = 0;
    var visible = [];

    function updateVisible() {
      var active = document.querySelector('.filter-bar button[aria-pressed="true"]');
      var filter = active ? active.getAttribute("data-filter") : "all";
      visible = [];
      if (!grid) return;
      grid.querySelectorAll("figure").forEach(function (fig, idx) {
        var cat = fig.getAttribute("data-category");
        var show = filter === "all" || cat === filter;
        fig.style.display = show ? "" : "none";
        if (show) visible.push(idx);
      });
    }

    function openAt(index) {
      if (!lb || !imgEl) return;
      var i = visible.indexOf(index);
      if (i < 0) return;
      current = i;
      var item = items[index];
      imgEl.src = item.src;
      imgEl.alt = item.alt;
      lb.hidden = false;
      document.body.style.overflow = "hidden";
      closeBtn && closeBtn.focus();
    }

    function close() {
      if (!lb) return;
      lb.hidden = true;
      document.body.style.overflow = "";
    }

    function step(delta) {
      if (visible.length === 0) return;
      current = (current + delta + visible.length) % visible.length;
      var idx = visible[current];
      var item = items[idx];
      if (imgEl) {
        imgEl.src = item.src;
        imgEl.alt = item.alt;
      }
    }

    document.querySelectorAll(".filter-bar button").forEach(function (btn) {
      btn.addEventListener("click", function () {
        document.querySelectorAll(".filter-bar button").forEach(function (b) {
          b.setAttribute("aria-pressed", b === btn ? "true" : "false");
        });
        updateVisible();
      });
    });

    if (grid) {
      grid.addEventListener("click", function (e) {
        var t = e.target;
        if (!(t instanceof Element)) return;
        var btn = t.closest("button[data-lightbox-index]");
        if (!btn) return;
        var idx = parseInt(btn.getAttribute("data-lightbox-index") || "0", 10);
        updateVisible();
        openAt(idx);
      });
    }

    closeBtn && closeBtn.addEventListener("click", close);
    prevBtn && prevBtn.addEventListener("click", function () { step(-1); });
    nextBtn && nextBtn.addEventListener("click", function () { step(1); });
    lb &&
      lb.addEventListener("click", function (e) {
        if (e.target === lb) close();
      });
    document.addEventListener("keydown", function (e) {
      if (!lb || lb.hidden) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") step(-1);
      if (e.key === "ArrowRight") step(1);
    });

    updateVisible();
  })();
</script>
