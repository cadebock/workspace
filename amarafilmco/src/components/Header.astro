---
import { siteConfig } from "../site.config";
import PrimaryCTA from "./PrimaryCTA.astro";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;

const links = [
  { href: "/", label: "Home" },
  { href: "/about/", label: "About" },
  { href: "/services/", label: "Services" },
  { href: "/portfolio/", label: "Portfolio" },
  { href: "/films/", label: "Films" },
  { href: "/investment/", label: "Investment" },
  { href: "/faq/", label: "FAQ" },
  { href: "/blog/", label: "Blog" },
  { href: "/contact/", label: "Contact" },
];

function isCurrent(href: string): boolean {
  const p = pathname.replace(/\/$/, "") || "/";
  const h = href.replace(/\/$/, "") || "/";
  if (h === "/") return p === "/";
  return p === h || p.startsWith(h + "/");
}
---

<header class="site-header" id="top">
  <div class="wrap nav-inner">
    <a class="logo" href="/">{siteConfig.businessName.split(" ")[0]}</a>
    <button
      type="button"
      class="nav-toggle"
      id="navToggle"
      aria-expanded="false"
      aria-controls="navMenu"
      aria-label="Open menu"
    >
      <span class="nav-toggle-text">Menu</span>
    </button>
    <nav id="navMenu" aria-label="Primary">
      <ul class="nav-list">
        {
          links.map(({ href, label }) => (
            <li>
              <a href={href} aria-current={isCurrent(href) ? "page" : undefined}>
                {label}
              </a>
            </li>
          ))
        }
        <li>
          <button
            type="button"
            class="btn btn-ghost theme-toggle"
            id="themeToggle"
            aria-pressed="false"
            aria-label="Toggle dark mode"
          >
            <span class="theme-toggle-label">Dark</span>
          </button>
        </li>
        <li>
          <PrimaryCTA label="Book an intro call" />
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  (function () {
    var header = document.querySelector(".site-header");
    var toggle = document.getElementById("navToggle");
    var menu = document.getElementById("navMenu");
    if (!header || !toggle || !menu) return;
    var links = menu.querySelectorAll("a");
    var toggleText = toggle.querySelector(".nav-toggle-text");
    toggle.addEventListener("click", function () {
      var open = header.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      if (toggleText) toggleText.textContent = open ? "Close" : "Menu";
    });
    links.forEach(function (a) {
      a.addEventListener("click", function () {
        header.classList.remove("is-open");
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Open menu");
        if (toggleText) toggleText.textContent = "Menu";
      });
    });
    var themeToggle = document.getElementById("themeToggle");
    if (themeToggle) {
      var label = themeToggle.querySelector(".theme-toggle-label");
      var docEl = document.documentElement;
      var applyTheme = function (theme) {
        docEl.dataset.theme = theme;
        if (typeof localStorage !== "undefined") {
          localStorage.setItem("theme", theme);
        }
        var isDark = theme === "dark";
        themeToggle.setAttribute("aria-pressed", String(isDark));
        if (label) {
          label.textContent = isDark ? "Light" : "Dark";
        }
      };
      var current = docEl.dataset.theme || "light";
      applyTheme(current);
      themeToggle.addEventListener("click", function () {
        var next = (docEl.dataset.theme || "light") === "dark" ? "light" : "dark";
        applyTheme(next);
      });
    }
  })();
</script>
